# Backend (Railway Python service)
# PORT is injected automatically by Railway.

# Optional PostgreSQL connection
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# Comma-separated frontend origins, or * for all
CORS_ALLOWED_ORIGINS=*

# Frontend (Railway Node service) — set these as build-time variables
# VITE_API_BASE=https://your-backend.up.railway.app
# VITE_WS_BASE=wss://your-backend.up.railway.app

# Leave VITE_* unset when frontend and backend share the same Railway domain
# (same-origin requests and WebSocket).
